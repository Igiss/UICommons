{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Login Test Data",
  "type": "object",
  "required": ["cases"],
  "properties": {
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test_id", "title", "data", "expected"],
        "properties": {
          "test_id": { "type": "string" },
          "title": { "type": "string" },
          "priority": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "data": { "type": "object" },
          "expected": { "type": "object" }
        }
      }
    }
  }
}
